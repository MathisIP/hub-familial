# Configuration du foyer — copier vers `.env` et renseigner.
# ⚠ `.env` et `credentials.json` ne sont JAMAIS versionnés (voir .gitignore).
#
# Les 5 IDs de classeurs (segment entre /d/ et /edit dans l'URL Google Sheets).
BUDGET_SHEET_ID=
TODO_SHEET_ID=
REPAS_SHEET_ID=
CADEAUX_SHEET_ID=
EVENEMENTS_SHEET_ID=

# Agendas familiaux (module Agenda). Un ou plusieurs IDs Google Agenda séparés
# par des virgules. Chaque agenda doit être PARTAGÉ avec le compte de service, et
# l'API Google Calendar activée dans le projet GCP.
AGENDA_IDS=

# Dossier Drive « À classer » — cible du bouton « Importer » de l'accueil.
DRIVE_A_CLASSER_URL=

# Dossier Drive racine « Hub Familial » — parcouru par l'explorateur de l'accueil
# (navigation + ouverture des fichiers). Coller l'URL du dossier (…/folders/<id>).
DRIVE_HUB_URL=

# --- Base de données multi-foyer (version vendable) — voir MIGRATION_SAAS.md ---
# Chaîne de connexion Postgres (Neon, région UE). Tant qu'elle est vide, l'app
# reste sur Google Sheets. Utiliser l'URL « pooled » (…-pooler…) + sslmode=require.
DATABASE_URL=

# --- Identifiants du compte de service Google (accès aux données) ---
# LOCAL : laisser vide → le fichier ./credentials.json est utilisé.
# HÉBERGÉ (Vercel…) : coller ICI tout le contenu de credentials.json (sur une ligne).
GOOGLE_CREDENTIALS_JSON=
# GOOGLE_CREDENTIALS_PATH=./credentials.json   # chemin alternatif du fichier (local)

# --- Authentification d'accès (Auth.js / connexion Google) ---
# Secret de signature des sessions. Générer : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
# Client OAuth Google (type « Application Web ») — voir DEPLOIEMENT.md
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Adresses Google autorisées à se connecter (séparées par des virgules)
EMAILS_AUTORISES=
